<!DOCTYPE html>
<html lang="gu">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css">  
  <title>First Program in Mobile</title>
</head>
<body>
  <div class="container mt-4">
    <div class="jumbotron p-4">
      <h3 class="text-center mb-4">Registration Form</h3>
      
      <div class="form-group">
         <label for="name">Name</label>
         <input type="text" id="name" class="form-control" placeholder="Enter your name">
      </div>
      
      <div class="form-group">
        <label for="fname">Father Name</label>
        <input type="text" id="fname" class="form-control" placeholder="Enter father's name">
      </div>
      
      <div class="form-group">
        <label for="mono">Mobile No.</label>
        <input type="number" id="mono" class="form-control" placeholder="Enter mobile number">
      </div>
      
      <div class="form-group mt-4">
        <button id="submitbtn" class="btn btn-primary btn-block">Submit</button>
      </div>
      
      <hr>

      <div id="displayArea" class="alert alert-success mt-4" style="display:none;">
        <h5 class="alert-heading">Submitted Data:</h5>
        <p class="mb-1"><strong>Name:</strong> <span id="outname"></span></p>
        <p class="mb-1"><strong>Father Name:</strong> <span id="outfname"></span></p>
        <p class="mb-1"><strong>Mobile No:</strong> <span id="outmono"></span></p>
      </div>

    </div>
  </div>

  <script>
    const submitbtn = document.getElementById('submitbtn');
    const displayArea = document.getElementById('displayArea');
    
    submitbtn.addEventListener('click', () => {
      const username = document.getElementById('name').value.trim();
      const fathername = document.getElementById('fname').value.trim();
      const mobileno = document.getElementById('mono').value.trim();
      
      if(username === "" || fathername === "" || mobileno === ""){
        alert("Please fill all fields!");
        return;
      }
      
      document.getElementById('outname').textContent = username;
      document.getElementById('outfname').textContent = fathername;
      document.getElementById('outmono').textContent = mobileno;
      
      displayArea.style.display = 'block';
    });
  </script>
</body>
</html>
